--- !u!114 &345076239
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 345076225}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8c9a110b57d7e0a499a42ae4f0af9dc9, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  notificationChannelId: habit_reminders
  notificationChannelName: "\u0423\u0433\u0430\u0434\u0430\u0439 \u0444\u0438\u043B\u044C\u043C
    \u0421\u0421\u0421\u0420 \u043F\u043E \u043A\u0430\u0434\u0440\u0443"
  notificationTexts:
  - "\u0423\u0433\u0430\u0434\u0430\u0435\u0448\u044C \u0444\u0438\u043B\u044C\u043C
    \u043F\u043E \u043A\u0430\u0434\u0440\u0443 \u0441 \u043B\u0435\u0433\u0435\u043D\u0434\u0430\u0440\u043D\u043E\u0439
    \u0442\u0440\u043E\u0439\u043A\u043E\u0439? \u0422\u043E\u043B\u044C\u043A\u043E
    \u0434\u043B\u044F \u0437\u043D\u0430\u0442\u043E\u043A\u043E\u0432 \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E
    \u043A\u0438\u043D\u043E!"
  - "\u041D\u0435 \u043A\u0430\u0436\u0434\u044B\u0439 \u043E\u0442\u043B\u0438\u0447\u0438\u0442
    \xAB\u041A\u0430\u0432\u043A\u0430\u0437\u0441\u043A\u0443\u044E \u043F\u043B\u0435\u043D\u043D\u0438\u0446\u0443\xBB
    \u043E\u0442 \xAB\u0411\u0440\u0438\u043B\u043B\u0438\u0430\u043D\u0442\u043E\u0432\u043E\u0439
    \u0440\u0443\u043A\u0438\xBB \u043F\u043E \u043E\u0434\u043D\u043E\u043C\u0443
    \u043A\u0430\u0434\u0440\u0443. \u0410 \u0442\u044B \u0441\u043C\u043E\u0436\u0435\u0448\u044C?"
  - "\u0422\u0432\u043E\u044F \u0431\u0430\u0431\u0443\u0448\u043A\u0430 \u043D\u0430\u0432\u0435\u0440\u043D\u044F\u043A\u0430
    \u0437\u043D\u0430\u0435\u0442 \u044D\u0442\u043E\u0442 \u0444\u0438\u043B\u044C\u043C.
    \u0410 \u0442\u044B? \u0414\u043E\u043A\u0430\u0436\u0438, \u0447\u0442\u043E
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0435 \u043A\u0438\u043D\u043E
    \u2014 \u044D\u0442\u043E \u0442\u0432\u043E\u0451!"
  - "\u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u0442\u044B \u0433\u0443\u0440\u0443
    \u0441\u043E\u0432\u0435\u0442\u0441\u043A\u043E\u0433\u043E \u043A\u0438\u043D\u043E?
    \u0412\u043E\u0442 \u043F\u0440\u043E\u0441\u0442\u043E\u0439 \u043A\u0430\u0434\u0440
    \u0438\u0437 \u043F\u0440\u043E\u0441\u0442\u043E\u0433\u043E \u0444\u0438\u043B\u044C\u043C\u0430. "
  - "\u0422\u0432\u043E\u0439 \u0432\u043D\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u0439
    \u043A\u0438\u043D\u043E\u043C\u0430\u043D \u0441\u043E\u0441\u043A\u0443\u0447\u0438\u043B\u0441\u044F
    \u043F\u043E \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u043C\u0443 \u043A\u0438\u043D\u043E.
    \u041F\u043E\u0440\u0430 \u0434\u0430\u0442\u044C \u0435\u043C\u0443 \u0440\u0430\u0431\u043E\u0442\u0443! "
